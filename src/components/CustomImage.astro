---
import { If } from '@splendidlabz/astro'
import { Picture } from 'astro:assets'

/**
 * The custom image component built step-by-step in the Improvements lesson.
 * Splendid Astro's `Image` contains all of these fixes (and more) — this file
 * shows you what happens inside.
 */
const images = import.meta.glob('/src/assets/**/*.{jpeg,jpg,png,gif,avif,webp}')

const {
  src,
  caption = '',
  widths = [400, 800, 1200, 1600],
  formats = ['avif', 'webp'],
  ...rest
} = Astro.props

// Building a custom importer
const key = Object.keys(images).find(key => key.startsWith(src))
if (!key) throw new Error(`File ${src} not found`)
const file = await images[key]()
const image = file.default

// Append the original width and drop widths larger than the original
const finalWidths = [...widths, image.width].filter(
  width => width <= image.width,
)
---

<figure>
  <Picture src={image} {formats} widths={finalWidths} {...rest} />
  <If condition={caption}>
    <figcaption>{caption}</figcaption>
  </If>
</figure>
