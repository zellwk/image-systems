---
import Base from './Base.astro'

// Shared frame for specimen pages: title, lede, and a pointer to the code.
const { title, lede, code } = Astro.props
---

<Base>
  <div class="content prose max-w-narrow mx-auto vertical gap-4">
    <header class="vertical gap-1">
      <h1>{title}</h1>
      {lede && <p class="text-zinc-600">{lede}</p>}
      {code && <p class="text-sm text-zinc-500">Code: <code>{code}</code></p>}
    </header>

    <slot />

    <p><a href="/">← Back to the examples</a></p>
  </div>
</Base>
