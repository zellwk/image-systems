---
import Image from '@/components/CustomImage.astro'
import Specimen from '@/layouts/Specimen.astro'
import { Image as SplendidImage } from '@splendidlabz/astro'
---

<Specimen
  title="Improvements over Image and Picture"
  lede="Write the image path straight into src — no import statements, automatic widths, formats, and a figure wrapper."
  code="src/pages/improvements.astro + src/components/CustomImage.astro"
>
  <h2>The custom component, built in the lesson</h2>
  <p>
    <code>CustomImage.astro</code> globs <code>/src/assets</code>, finds the
    file from the <code>src</code> string, appends the original width to
    <code>widths</code>, and wraps everything in a <code>figure</code>.
  </p>
  <Image
    src="/src/assets/image1.png"
    alt="A red vintage bicycle leaning against a pastel yellow wall"
    caption="Rendered by src/components/CustomImage.astro"
  />

  <h2>Splendid Astro's Image component</h2>
  <p>
    All of those fixes (and more) ship in
    <code>@splendidlabz/astro</code>'s <code>Image</code>.
  </p>
  <SplendidImage
    src="/src/assets/image2.png"
    alt="A stack of colorful hardcover books on a wooden table"
    caption="Rendered by Splendid Astro's Image component"
  />
</Specimen>
